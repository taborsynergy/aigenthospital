# ── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AI model ──────────────────────────────────────────────────────────────
MODEL=claude-sonnet-4-6
MAX_TOKENS=1024

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./tabor_agent.db

# ── Admin dashboard ───────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-in-production

# ── Stripe (leave blank to skip billing features) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...           # Create a recurring monthly price in Stripe dashboard

# ── Twilio (leave blank to skip SMS features) ─────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_DEFAULT_NUMBER=+15125550100  # Your Twilio sending number

# ── Email / SMTP (for White Label quote notifications) ────────────────────
# Use Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password          # 16-char App Password, NOT your Gmail login password
NOTIFY_EMAIL=admin@tabor.taborsynergy.com

# ── Server ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
BASE_URL=https://aifrontdesk.taborsynergy.com   # Public URL (used for Stripe redirects)
