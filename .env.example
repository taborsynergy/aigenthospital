# .env.example - Environment Variables for Aigenthospital
# Copy this file to .env and fill in your values.

# FastAPI server configuration
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Database configuration
DATABASE_URL=sqlite:///./tabor_agent.db

# Admin panel authentication - IMPORTANT: Change this to a strong, unique password in .env
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_PANEL_PATH=/ts-mgmt

# Anthropic API Key (for AI agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe API Keys (for billing/payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Twilio API Credentials (for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SENDER_PHONE=your_twilio_phone_number_here

# Email SMTP Configuration (for sending emails)
SMTP_SERVER=your_smtp_server
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_SENDER=your_email_sender

# MOCK_MODE for local development/testing (set to 1 to enable)
MOCK_MODE=1

# Security — CORS allowed origins (comma-separated). Use * for local dev only.
ALLOWED_ORIGINS=*

# Enable API docs (/docs, /redoc, /openapi.json) — set to true in dev ONLY, never in production
DEBUG_MODE=true

# Render.com specific, if deploying there
# RENDER_EXTERNAL_HOSTNAME=your_render_hostname